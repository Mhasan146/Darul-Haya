# ─── Email (Resend) — powers the contact form ──────────────────────────────────
# Sign up at resend.com (free tier covers transactional email)
RESEND_API_KEY=re_...
# "From" address (must be on a Resend-verified domain for production)
FROM_EMAIL=noreply@darulhaya.com
# Where contact-form submissions are emailed
CONTACT_EMAIL=info@darulhaya.com

# ─── Public links ──────────────────────────────────────────────────────────────
# Your Moodle install — the "Student Login" button points here
NEXT_PUBLIC_MOODLE_URL=https://learn.darulhaya.com
# Public site URL
NEXT_PUBLIC_APP_URL=https://darulhaya.com

# ─── Analytics (Google Analytics 4) — optional ─────────────────────────────────
# Create a free GA4 property at analytics.google.com and paste its Measurement
# ID here. When set, the site loads GA (consent-gated) + a cookie banner.
# Leave unset to disable analytics entirely (no script, no banner).
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
